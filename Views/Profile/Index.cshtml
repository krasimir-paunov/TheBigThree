@using TheBigThree.Web.ViewModels
@model ProfileViewModel

@{
    ViewBag.Title = "Player Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 class="hub-title mb-0">@ViewBag.Title</h2>
            <div class="badge bg-info text-dark shadow-sm">User Dashboard</div>
        </div>

        <div class="row g-4 align-items-start">

            <div class="col-lg-4">
                <div class="profile-hero-card p-4 text-center shadow-lg">

                    @{
                        string rankClass = Model.Rank switch
                        {
                            "Legendary Collector" => "rank-legendary",
                            "Superstar Collector" => "rank-superstar",
                            "Popular Collector" => "rank-popular",
                            "Rising Star" => "rank-rising",
                            "Novice Collector" => "rank-novice",
                            _ => "rank-newcomer"
                        };

                        string avatarAnimClass = Model.Rank switch
                        {
                            "Legendary Collector" => "avatar-ring-legendary",
                            "Superstar Collector" => "avatar-ring-legendary",
                            "Popular Collector" => "avatar-ring-popular",
                            "Rising Star" => "avatar-ring-rising",
                            _ => ""
                        };

                        string rankTooltip = Model.Rank switch
                        {
                            "Legendary Collector" => "100+ stars — you've reached the top!",
                            "Superstar Collector" => "30+ stars earned. Almost legendary!",
                            "Popular Collector" => "10+ stars earned. Keep going!",
                            "Rising Star" => "5+ stars earned. You're on the rise!",
                            "Novice Collector" => "1+ stars earned. Just getting started!",
                            _ => "Star a collection to start climbing the ranks!"
                        };
                    }

                    <div class="d-flex justify-content-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" class="avatar-ring @avatarAnimClass" alt="Avatar" />
                        }
                        else
                        {
                            <div class="avatar-initials @avatarAnimClass">
                                @Model.Username.Substring(0, Math.Min(2, Model.Username.Length)).ToUpper()
                            </div>
                        }
                    </div>

                    <p class="text-white fw-bold mb-1" style="font-size: 1.6rem;">@Model.Username</p>
                    <p class="text-muted small mb-3">@Model.Email</p>

                    <div class="mb-4">
                        <span class="rank-badge @rankClass"
                              style="font-size: 13px; padding: 5px 14px;"
                              data-bs-toggle="tooltip"
                              data-bs-placement="top"
                              title="@rankTooltip">
                            <i class="bi bi-trophy-fill me-1"></i>@Model.Rank
                        </span>
                    </div>

                    <div class="d-flex gap-3 mb-4">
                        <div class="stat-pill">
                            <div class="stat-number text-warning">@Model.TotalStarsEarned</div>
                            <div class="stat-label">Stars Earned</div>
                        </div>
                        <div class="stat-pill">
                            <div class="stat-number text-info">@Model.FavoriteCollections.Count()</div>
                            <div class="stat-label">Starred</div>
                        </div>
                    </div>

                    @if (Model.OwnCollectionId.HasValue)
                    {
                        <hr class="border-secondary opacity-25" />
                        <p class="text-muted small text-uppercase mb-2" style="font-size: 0.65rem; letter-spacing: 0.1em;">
                            <i class="bi bi-collection-fill me-1 text-warning"></i>My Big Three
                        </p>
                        <a asp-controller="Collection" asp-action="Details" asp-route-id="@Model.OwnCollectionId"
                           class="own-collection-card mb-3">
                            <div class="own-covers">
                                @foreach (string imgUrl in Model.OwnCollectionGameImages)
                                {
                                    <div class="own-cover-slot">
                                        <img src="@imgUrl" alt="Game Cover" />
                                    </div>
                                }
                            </div>
                            <div class="own-card-body">
                                <p class="own-title">@Model.OwnCollectionTitle</p>
                                <span style="font-size: 0.78rem; color: rgba(255,193,7,0.8);">
                                    <i class="bi bi-eye-fill me-1 text-info"></i>View
                                </span>
                            </div>
                        </a>
                    }
                    else
                    {
                        <hr class="border-secondary opacity-25" />
                        <p class="text-muted small fst-italic mb-3" style="font-size: 0.78rem;">
                            You haven't built your Big Three yet.
                        </p>
                        <a asp-controller="Collection" asp-action="Add"
                           class="btn btn-sm btn-outline-warning rounded-pill px-4 fw-bold mb-3">
                            <i class="bi bi-plus-circle me-1"></i>Build My Big Three
                        </a>
                    }

                    <hr class="border-secondary opacity-25" />

                    <div class="mt-3">
                        <button type="button"
                                class="btn btn-sm btn-outline-info rounded-pill px-3 fw-bold mb-3"
                                onclick="document.getElementById('avatarForm').style.display = document.getElementById('avatarForm').style.display === 'none' ? 'block' : 'none'">
                            <i class="bi bi-image me-1"></i>
                            @(string.IsNullOrEmpty(Model.AvatarUrl) ? "Set Custom Avatar" : "Change Avatar")
                        </button>

                        <div id="avatarForm" style="display: none;" class="avatar-form-area">
                            <form asp-controller="Profile" asp-action="UpdateAvatar" method="post">
                                <div class="input-group input-group-sm">
                                    <input type="url" name="avatarUrl" value="@Model.AvatarUrl"
                                           class="form-control bg-dark text-light border-secondary"
                                           placeholder="Paste image URL..." />
                                    <button type="submit" class="btn btn-outline-info fw-bold">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <a asp-controller="Collection" asp-action="Mine"
                           class="btn btn-outline-info rounded-pill fw-bold py-2">
                            <i class="bi bi-pencil-square me-2"></i>Manage My Collection
                        </a>
                    </div>

                </div>
            </div>

            <div class="col-lg-8">
                <div class="profile-hero-card p-4 shadow-lg">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="text-white fw-bold mb-0">
                            <i class="bi bi-star-fill text-warning me-2" style="font-size: 1rem;"></i>My Favorites
                        </h4>
                        <span class="text-muted small fst-italic">Collections you've starred</span>
                    </div>

                    @if (!Model.FavoriteCollections.Any())
                    {
                        <div class="text-center py-5">
                            <div class="opacity-25 mb-3">
                                <i class="bi bi-star" style="font-size: 4rem;"></i>
                            </div>
                            <p class="text-muted">You haven't starred any collections yet.</p>
                            <a asp-controller="Collection" asp-action="All"
                               class="btn btn-sm btn-outline-warning rounded-pill px-4 mt-2 fw-bold">
                                Explore Hub
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var fav in Model.FavoriteCollections)
                            {
                                <div class="col-md-6">
                                    <a asp-controller="Collection" asp-action="Details" asp-route-id="@fav.Id"
                                       class="fav-card">
                                        <div class="fav-covers">
                                            @foreach (string imgUrl in fav.GameImages)
                                            {
                                                <div class="fav-cover-slot">
                                                    <img src="@imgUrl" alt="Game Cover" />
                                                </div>
                                            }
                                        </div>
                                        <div class="fav-card-body">
                                            <div style="min-width: 0;">
                                                <p class="fav-title">@fav.Title</p>
                                                <p class="fav-meta">by @fav.Publisher</p>
                                            </div>
                                            <span class="fav-stars ms-2">⭐ @fav.TotalStars</span>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-bs-toggle="tooltip"]')
                .forEach(el => new bootstrap.Tooltip(el));
        });
    </script>
}