@using TheBigThree.Web.ViewModels
@model CollectionQueryModel

@{
    ViewBag.Title = "Community Hub";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hub.css" asp-append-version="true" />
}

<div class="hub-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
    <div class="container">

        <div class="row align-items-center mb-5 px-3">
            <div class="col-md-3 d-none d-md-block"></div>

            <div class="col-md-6 text-center">
                <h2 class="hub-title mb-0">@ViewBag.Title</h2>
                <div class="badge bg-info text-dark shadow-sm">Explore the Big Three</div>
            </div>

            <div class="col-md-3 text-center text-md-end mt-3 mt-md-0">
                @if (User.Identity?.IsAuthenticated == true && ViewBag.UserHasCollection == false)
                {
                    <a asp-controller="Collection" asp-action="Add" class="btn btn-warning px-4 rounded-pill shadow fw-bold">
                        <i class="bi bi-plus"></i> Create Your Own
                    </a>
                }
                else if (User.Identity?.IsAuthenticated == false)
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-info px-4 rounded-pill fw-bold">
                        <i class="bi bi-box-arrow-in-right"></i> Login to Create
                    </a>
                }
            </div>
        </div>

        <div class="container mb-4">
            <form method="get" asp-action="All" class="mb-3">
                <div class="row g-2 align-items-center">
                    <div class="col-md-5">
                        <input type="text"
                               name="SearchTerm"
                               value="@Model.SearchTerm"
                               class="form-control bg-dark text-light border-secondary"
                               placeholder="Search collections..." />
                    </div>
                    <div class="col-md-3">
                        <select name="GenreFilter" class="form-select bg-dark text-light border-secondary">
                            <option value="">All Genres</option>
                            @foreach (var genre in Model.Genres)
                            {
                                @if (Model.GenreFilter == genre)
                                {
                                    <option value="@genre" selected>@genre</option>
                                }
                                else
                                {
                                    <option value="@genre">@genre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="hidden" name="Sorting" value="@Model.Sorting" />
                        <button type="submit" class="btn btn-info rounded-pill px-4 fw-bold w-100">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>
                    <div class="col-md-2">
                        <a id="clearBtn" asp-action="All" class="btn btn-outline-secondary rounded-pill px-4 w-100">Clear</a>
                    </div>
                </div>
            </form>

            <div class="d-flex align-items-center gap-2">
                <span class="text-white-50 small fw-bold text-uppercase me-2" style="letter-spacing: 1.5px; font-size: 0.7rem;">Sort by:</span>
                <a asp-action="All"
                   asp-route-Sorting="Newest"
                   asp-route-SearchTerm="@Model.SearchTerm"
                   asp-route-GenreFilter="@Model.GenreFilter"
                   class="btn btn-sm @(Model.Sorting == "Newest" || string.IsNullOrEmpty(Model.Sorting) ? "btn-info" : "btn-outline-info") rounded-pill px-3 py-1"
                   style="font-size: 0.7rem; font-weight: 700;">
                    <i class="bi bi-clock-history me-1"></i> NEWEST
                </a>
                <a asp-action="All"
                   asp-route-Sorting="Stars"
                   asp-route-SearchTerm="@Model.SearchTerm"
                   asp-route-GenreFilter="@Model.GenreFilter"
                   class="btn btn-sm @(Model.Sorting == "Stars" ? "btn-info" : "btn-outline-info") rounded-pill px-3 py-1"
                   style="font-size: 0.7rem; font-weight: 700;">
                    <i class="bi bi-star-fill me-1"></i> STARS
                </a>
            </div>
            <hr class="border-secondary opacity-25 mt-3" />
        </div>

        <div class="row g-4 justify-content-center pb-5">
            @if (!Model.Collections.Any())
            {
                <div class="col-12 text-center py-5">
                    <h3 class="text-light opacity-50">No collections found.</h3>
                </div>
            }

            @foreach (CollectionAllViewModel collection in Model.Collections)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="collection-card h-100">

                        <div class="covers-strip">
                            @foreach (string imgUrl in collection.GameImages)
                            {
                                <div class="cover-slot">
                                    <img src="@imgUrl" alt="Game Cover" />
                                </div>
                            }
                        </div>

                        <div class="card-body-custom">
                            <p class="card-title-custom">@collection.Title</p>

                            <div class="curator-row">
                                @if (!string.IsNullOrEmpty(collection.AvatarUrl))
                                {
                                    <img src="@collection.AvatarUrl" class="curator-avatar" alt="avatar" />
                                }
                                else
                                {
                                    <div class="curator-initials">
                                        @collection.Publisher.Substring(0, 1).ToUpper()
                                    </div>
                                }
                                <a asp-controller="PublicProfile" asp-action="Index"
                                   asp-route-username="@collection.Publisher"
                                   class="curator-name text-decoration-none"
                                   onclick="event.stopPropagation();">@collection.Publisher</a>
                                @{
                                    string rankClass = collection.PublisherRank switch
                                    {
                                        "Legendary Collector" => "rank-legendary",
                                        "Superstar Collector" => "rank-superstar",
                                        "Popular Collector" => "rank-popular",
                                        "Rising Star" => "rank-rising",
                                        "Novice Collector" => "rank-novice",
                                        _ => "rank-newcomer"
                                    };
                                }
                                <span class="rank-badge @rankClass">@collection.PublisherRank</span>
                            </div>

                            <div class="card-footer-custom">
                                <span class="stars-count">⭐ @collection.TotalStars</span>
                                <a asp-controller="Collection" asp-action="Details" asp-route-id="@collection.Id"
                                   class="btn-view">
                                    <i class="bi bi-eye-fill me-1"></i>View
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        @{
            int totalPages = (int)Math.Ceiling((double)Model.TotalCollections / Model.CollectionsPerPage);
        }

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center align-items-center gap-2 pb-5">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-action="All"
                       asp-route-CurrentPage="@(Model.CurrentPage - 1)"
                       asp-route-Sorting="@Model.Sorting"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-GenreFilter="@Model.GenreFilter"
                       class="btn btn-outline-info rounded-pill px-4">
                        <i class="bi bi-arrow-left"></i> Prev
                    </a>
                }
                <span class="text-white-50 small px-3">Page @Model.CurrentPage of @totalPages</span>
                @if (Model.CurrentPage < totalPages)
                {
                    <a asp-action="All"
                       asp-route-CurrentPage="@(Model.CurrentPage + 1)"
                       asp-route-Sorting="@Model.Sorting"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-GenreFilter="@Model.GenreFilter"
                       class="btn btn-outline-info rounded-pill px-4">
                        Next <i class="bi bi-arrow-right"></i>
                    </a>
                }
            </div>
        }

    </div>
</div>

@section Scripts {
    <script src="~/js/hub.js" asp-append-version="true"></script>
}
