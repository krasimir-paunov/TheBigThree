@using TheBigThree.Web.ViewModels
@model CollectionMineViewModel?

@{
    ViewBag.Title = "My Big Three Collection";
}

@section Styles {
    <style>
        .mine-background {
            background: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.8)), url('/images/backgrounds/mine-background.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
        }

        .showcase-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
        }

        .game-cover {
            width: 100%;
            aspect-ratio: 3 / 4;
            object-fit: cover;
            border-radius: 0.5rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .game-description {
            font-size: 0.78rem;
            color: rgba(255, 255, 255, 0.55);
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .rank-label {
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            color: rgba(255, 255, 255, 0.35);
            text-transform: uppercase;
        }
    </style>
}

<div class="mine-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 class="hub-title mb-0">@ViewBag.Title</h2>
            <div class="badge bg-warning text-dark shadow-sm">Your Personal Hall of Fame</div>
        </div>

        @if (Model == null)
        {
            <div class="text-center py-5 d-flex flex-column align-items-center gap-3">
                <div class="d-flex flex-column align-items-center gap-2 py-4">

                    <div class="d-flex align-items-flex-end gap-3" style="align-items: flex-end;">

                        <div class="d-flex flex-column align-items-center">
                            <svg width="90" height="90" viewBox="0 0 80 80" fill="none" style="margin-bottom:6px;">
                                <path d="M22 12h36v22c0 9.941-8.059 18-18 18s-18-8.059-18-18V12z" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linejoin="round" />
                                <path d="M22 20H12a6 6 0 006 6h4" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" />
                                <path d="M58 20h10a6 6 0 01-6 6h-4" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" />
                                <path d="M40 52v8" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" />
                                <path d="M30 60h20" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" />
                                <text x="40" y="38" text-anchor="middle" font-size="16" font-weight="500" fill="rgba(255,255,255,0.35)" font-family="sans-serif">2</text>
                            </svg>
                            <div style="width:70px; height:55px; border-radius: 4px 4px 0 0; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);"></div>
                        </div>

                        <div class="d-flex flex-column align-items-center">
                            <svg width="120" height="120" viewBox="0 0 80 80" fill="none" style="margin-bottom:6px;">
                                <path d="M22 12h36v22c0 9.941-8.059 18-18 18s-18-8.059-18-18V12z" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linejoin="round" />
                                <path d="M22 20H12a6 6 0 006 6h4" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linecap="round" />
                                <path d="M58 20h10a6 6 0 01-6 6h-4" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linecap="round" />
                                <path d="M40 52v8" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linecap="round" />
                                <path d="M30 60h20" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linecap="round" />
                                <text x="40" y="38" text-anchor="middle" font-size="16" font-weight="500" fill="rgba(255,255,255,0.5)" font-family="sans-serif">1</text>
                            </svg>
                            <div style="width:84px; height:80px; border-radius: 4px 4px 0 0; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);"></div>
                        </div>

                        <div class="d-flex flex-column align-items-center">
                            <svg width="76" height="76" viewBox="0 0 80 80" fill="none" style="margin-bottom:6px;">
                                <path d="M22 12h36v22c0 9.941-8.059 18-18 18s-18-8.059-18-18V12z" stroke="rgba(255,255,255,0.22)" stroke-width="2" stroke-linejoin="round" />
                                <path d="M22 20H12a6 6 0 006 6h4" stroke="rgba(255,255,255,0.22)" stroke-width="2" stroke-linecap="round" />
                                <path d="M58 20h10a6 6 0 01-6 6h-4" stroke="rgba(255,255,255,0.22)" stroke-width="2" stroke-linecap="round" />
                                <path d="M40 52v8" stroke="rgba(255,255,255,0.22)" stroke-width="2" stroke-linecap="round" />
                                <path d="M30 60h20" stroke="rgba(255,255,255,0.22)" stroke-width="2" stroke-linecap="round" />
                                <text x="40" y="38" text-anchor="middle" font-size="16" font-weight="500" fill="rgba(255,255,255,0.25)" font-family="sans-serif">3</text>
                            </svg>
                            <div style="width:62px; height:40px; border-radius: 4px 4px 0 0; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);"></div>
                        </div>

                    </div>

                    <h3 class="text-light mb-0">You haven't built your Big Three yet</h3>
                    <p class="text-secondary mb-2">Every gamer has three games that define them. What are yours?</p>
                    <a asp-action="Add" class="btn btn-info btn-lg px-5 rounded-pill fw-bold shadow">
                        <i class="bi bi-plus-circle me-2"></i>Build My Big Three
                    </a>

                </div>

            </div>
        }
        else
        {
            <div class="showcase-card p-4 p-md-5 mx-auto" style="max-width: 900px;">

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4 pb-3"
                     style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <h4 class="text-white fw-bold mb-0">@Model.Title</h4>
                    <span class="badge bg-transparent text-white fs-6 px-3 py-2">
                        ⭐ @Model.TotalStars Stars
                    </span>
                </div>

                <div class="row g-4 mb-4">
                    @for (int i = 0; i < Model.Games.Count; i++)
                    {
                        GameDetailsViewModel game = Model.Games[i];
                        <div class="col-md-4">
                            <div class="text-center mb-2">
                                <span class="rank-label">#@(i + 1)</span>
                            </div>
                            <img src="@game.ImageUrl" alt="@game.Title" class="game-cover mb-3" />
                            <p class="text-white fw-bold mb-1 text-center" style="font-size: 0.9rem;">@game.Title</p>
                            <p class="text-center mb-1" style="font-size: 0.75rem; color: rgba(255,255,255,0.4);">@game.Genre</p>
                            <p class="game-description text-center">@game.Description</p>
                        </div>
                    }
                </div>

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 pt-3"
                     style="border-top: 1px solid rgba(255,255,255,0.1);">
                    <a asp-action="Details" asp-route-id="@Model.Id"
                       class="btn btn-outline-info rounded-pill px-4 fw-bold">
                        <i class="bi bi-eye-fill me-2"></i>View Full Details
                    </a>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id"
                           class="btn btn-warning rounded-pill px-4 fw-bold text-dark">
                            <i class="bi bi-pencil-square me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id"
                           class="btn btn-danger rounded-pill px-4 fw-bold">
                            <i class="bi bi-trash3-fill me-1"></i>Delete
                        </a>
                    </div>
                </div>

            </div>
        }

    </div>
</div>