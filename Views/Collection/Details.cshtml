@using TheBigThree.Web.ViewModels
@model CollectionDetailsViewModel

@section Styles {
	<style>
		.details-hero {
			width: 100vw;
			margin-left: calc(-50vw + 50%);
			background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.95)), url('/images/backgrounds/mine-background.jpg');
			background-size: cover;
			background-position: center;
			background-attachment: fixed;
			padding: 3rem 0 2.5rem;
			border-bottom: 1px solid rgba(255,255,255,0.06);
		}

		.details-body {
			width: 100vw;
			margin-left: calc(-50vw + 50%);
			background: linear-gradient(rgba(0,0,0,0.9), rgba(0,0,0,0.9)), url('/images/backgrounds/mine-background.jpg');
			background-size: cover;
			background-position: center;
			background-attachment: fixed;
			min-height: 60vh;
			padding-bottom: 4rem;
		}

		.publisher-avatar {
			width: 52px;
			height: 52px;
			border-radius: 50%;
			object-fit: cover;
			border: 2px solid rgba(13,202,240,0.5);
			box-shadow: 0 0 12px rgba(13,202,240,0.2);
		}

		.publisher-initials {
			width: 52px;
			height: 52px;
			border-radius: 50%;
			background: rgba(13,202,240,0.15);
			border: 2px solid rgba(13,202,240,0.4);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 0.9rem;
			font-weight: 700;
			color: rgba(13,202,240,0.9);
		}

		.game-card {
			background: rgba(255,255,255,0.04);
			border: 1.5px solid rgba(255,255,255,0.08);
			border-radius: 1rem;
			overflow: hidden;
			transition: border-color 0.2s ease, transform 0.2s ease;
			height: 100%;
		}

			.game-card:hover {
				border-color: rgba(13,202,240,0.3);
			}

		.game-cover-wrapper {
			width: 100%;
			aspect-ratio: 3 / 4;
			overflow: hidden;
			background: rgba(0,0,0,0.3);
		}

			.game-cover-wrapper img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				transition: transform 0.4s ease;
			}

		.game-card-body {
			padding: 1.25rem;
		}

		.game-title {
			font-size: 1.7rem;
			font-weight: 700;
			color: #fff;
			margin-bottom: 6px;
			font-family: var(--body-font);
			text-transform: none;
			letter-spacing: 0.05em;
			text-align: center;
		}

		.rank-label-subtle {
			font-size: 0.65rem;
			letter-spacing: 0.1em;
			color: rgba(255,255,255,0.3);
			text-transform: uppercase;
			margin-bottom: 4px;
		}

		.game-description {
			font-size: 0.9rem;
			color: rgba(255,255,255,0.55);
			line-height: 1.6;
			margin-top: 8px;
		}

		.comments-section {
			max-width: 760px;
			margin: 0 auto;
		}

		.comment-card {
			background: rgba(255,255,255,0.03);
			border: 1px solid rgba(255,255,255,0.06);
			border-radius: 0.75rem;
			padding: 1rem 1.25rem;
			margin-bottom: 0.75rem;
		}

		.comment-avatar {
			width: 32px;
			height: 32px;
			border-radius: 50%;
			object-fit: cover;
			border: 1px solid rgba(13,202,240,0.3);
		}

		.comment-initials {
			width: 32px;
			height: 32px;
			border-radius: 50%;
			background: rgba(13,202,240,0.1);
			border: 1px solid rgba(13,202,240,0.25);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 0.65rem;
			font-weight: 700;
			color: rgba(13,202,240,0.8);
			flex-shrink: 0;
		}

		.modal {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			z-index: 1055;
		}
	</style>
}

@{
	ViewBag.Title = Model.Title;
}

<div class="details-hero">
	<div class="container">
		<div class="d-flex flex-wrap align-items-center justify-content-between gap-4">

			<div class="d-flex align-items-center gap-4">
				@if (!string.IsNullOrEmpty(Model.AvatarUrl))
				{
					<img src="@Model.AvatarUrl" class="publisher-avatar" alt="avatar" />
				}
				else
				{
					<div class="publisher-initials">
						@Model.Publisher.Substring(0, Math.Min(2, Model.Publisher.Length)).ToUpper()
					</div>
				}
				<div>
					<p class="text-muted mb-0" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px;">Curated by</p>
					<p class="text-info fw-bold fs-5 mb-0">@Model.Publisher</p>
				</div>
				<div class="vr bg-secondary opacity-25 d-none d-md-block" style="height: 40px;"></div>
				<div>
					<h2 class="text-white fw-bold mb-0" style="font-family: var(--heading-font); letter-spacing: 1px;">@Model.Title</h2>
				</div>
			</div>

			<div class="d-flex align-items-center gap-3 flex-wrap">
				<div class="text-center">
					<span class="h3 text-warning fw-bold mb-0">⭐ @Model.TotalStars</span>
					<div class="text-muted" style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1px;">Total Stars</div>
				</div>

				<div class="d-flex gap-2">
					@if (User.Identity?.IsAuthenticated == true && User.Identity.Name?.Split('@')[0] != Model.Publisher)
					{
						@if (ViewBag.IsStarred == true)
						{
							<form asp-controller="Collection" asp-action="RemoveStar" asp-route-id="@Model.Id" method="post">
								<button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-4 fw-bold">
									<i class="bi bi-star me-1"></i>Unstar
								</button>
							</form>
						}
						else
						{
							<form asp-controller="Collection" asp-action="Star" asp-route-id="@Model.Id" method="post">
								<button type="submit" class="btn btn-sm btn-warning rounded-pill px-4 fw-bold">
									<i class="bi bi-star-fill me-1"></i>Give Star
								</button>
							</form>
						}
					}
					else if (User.Identity?.IsAuthenticated == true && User.Identity.Name?.Split('@')[0] == Model.Publisher)
					{
						<span class="badge bg-secondary opacity-75 py-2 px-3 rounded-pill" style="font-size: 0.7rem;">
							<i class="bi bi-person-check-fill me-1"></i>My Collection
						</span>
					}

					@if (User.IsInRole("Administrator"))
					{
						<button type="button"
								class="btn btn-sm btn-outline-danger rounded-pill px-4 fw-bold"
								data-bs-toggle="modal"
								data-bs-target="#adminDeleteModal">
							<i class="bi bi-shield-fill me-1"></i>Admin Delete
						</button>
					}
				</div>
			</div>

		</div>
	</div>
</div>


<div class="details-body">
	<div class="container py-5">

		<div class="row g-4 justify-content-center mb-5">
			@for (int i = 0; i < Model.Games.Count; i++)
			{
				GameDetailsViewModel game = Model.Games[i];
				<div class="col-lg-4 col-md-6">
					<div class="game-card">
						<div class="game-cover-wrapper">
							<img src="@game.ImageUrl" alt="@game.Title" />
						</div>
						<div class="game-card-body">
							<p class="game-title">@game.Title</p>
							<div class="text-center">
								<span class="badge rounded-pill bg-info text-dark px-3 mb-2" style="font-size: 0.7rem;">@game.Genre</span>
							</div>
							<p class="game-description">@game.Description</p>
						</div>
					</div>
				</div>
			}
		</div>


		<div class="comments-section">
			<h4 class="text-white fw-bold mb-4" id="comments">
				<i class="bi bi-chat-dots-fill me-2 text-info"></i>Comments
			</h4>

			@if (!Model.Comments.Any())
			{
				<p class="text-muted fst-italic">No comments yet. Be the first to share your thoughts!</p>
			}

			@foreach (var comment in Model.Comments)
			{
				<div class="comment-card">
					<div class="d-flex justify-content-between align-items-start mb-2">
						<div class="d-flex align-items-center gap-2">
							@if (!string.IsNullOrEmpty(comment.AvatarUrl))
							{
								<img src="@comment.AvatarUrl" class="comment-avatar" alt="avatar" />
							}
							else
							{
								<div class="comment-initials">
									@comment.UserName.Substring(0, Math.Min(2, comment.UserName.Length)).ToUpper()
								</div>
							}
							<div>
								<span class="text-info fw-bold" style="font-size: 0.9rem;">@comment.UserName</span>
								<span class="text-muted ms-2" style="font-size: 0.72rem;">
									@comment.CreatedOn.ToString("MMM dd, yyyy")
								</span>
							</div>
						</div>
						<div class="d-flex gap-2">
							@if (User.Identity?.IsAuthenticated == true && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId)
							{
								<button type="button"
										class="btn btn-sm btn-outline-danger rounded-pill px-3"
										data-bs-toggle="modal"
										data-bs-target="#deleteModal-@comment.Id">
									<i class="bi bi-trash"></i>
								</button>
							}
							@if (User.IsInRole("Administrator"))
							{
								<button type="button"
										class="btn btn-sm btn-outline-warning rounded-pill px-3"
										data-bs-toggle="modal"
										data-bs-target="#adminDeleteCommentModal-@comment.Id"
										title="Admin — Delete Comment"
										data-bs-placement="top">
									<i class="bi bi-shield-fill"></i>
								</button>
							}
						</div>
					</div>
					<p class="text-light mb-0" style="font-size: 0.88rem; word-break: break-word;">@comment.Content</p>
				</div>

				@if (User.Identity?.IsAuthenticated == true && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId)
				{
					<div class="modal fade" id="deleteModal-@comment.Id" tabindex="-1" aria-hidden="true">
						<div class="modal-dialog modal-dialog-centered">
							<div class="modal-content bg-dark border-secondary">
								<div class="modal-header border-secondary">
									<h5 class="modal-title text-white">Delete Comment</h5>
									<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
								</div>
								<div class="modal-body text-light">
									Are you sure you want to delete this comment? This action cannot be undone.
								</div>
								<div class="modal-footer border-secondary">
									<button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
									<form asp-controller="Comment" asp-action="Delete" method="post">
										<input type="hidden" name="commentId" value="@comment.Id" />
										<input type="hidden" name="collectionId" value="@Model.Id" />
										<button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
									</form>
								</div>
							</div>
						</div>
					</div>
				}

				@if (User.IsInRole("Administrator"))
				{
					<div class="modal fade" id="adminDeleteCommentModal-@comment.Id" tabindex="-1" aria-hidden="true">
						<div class="modal-dialog modal-dialog-centered">
							<div class="modal-content bg-dark border-secondary">
								<div class="modal-header border-secondary">
									<h5 class="modal-title text-white">Admin — Delete Comment</h5>
									<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
								</div>
								<div class="modal-body text-light">
									Delete comment by <span class="text-info fw-bold">@comment.UserName</span>?
									This action cannot be undone.
								</div>
								<div class="modal-footer border-secondary">
									<button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
									<form asp-controller="Comment" asp-action="Delete" method="post">
										<input type="hidden" name="commentId" value="@comment.Id" />
										<input type="hidden" name="collectionId" value="@Model.Id" />
										<button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
									</form>
								</div>
							</div>
						</div>
					</div>
				}
			}

			@if (User.Identity?.IsAuthenticated == true)
			{
				<div class="comment-card mt-4" style="border-color: rgba(13,202,240,0.15);">
					<h5 class="text-white fw-bold mb-3">Leave a Comment</h5>
					<form asp-controller="Comment" asp-action="Add" method="post">
						<input type="hidden" name="collectionId" value="@Model.Id" />
						<div class="mb-3">
							<textarea name="Content" id="Content"
								  class="form-control bg-dark text-light border-secondary"
								  rows="3"
								  placeholder="Share your thoughts..."></textarea>
						</div>
						@if (TempData["CommentError"] != null)
						{
							<div class="alert alert-danger rounded-3 py-2 px-3 mb-3" style="font-size: 0.85rem;">
								<i class="bi bi-exclamation-circle me-2"></i>@TempData["CommentError"]
							</div>
						}
						<button type="submit" class="btn btn-info rounded-pill px-4 fw-bold">
							<i class="bi bi-send-fill me-2"></i>Post Comment
						</button>
					</form>
				</div>
			}

			<div class="text-center mt-5">
				<a asp-action="All" class="btn btn-sm btn-outline-light rounded-pill px-4 opacity-50">
					<i class="bi bi-arrow-left me-2"></i>Back to Hub
				</a>
			</div>
		</div>

	</div>
</div>

@if (User.IsInRole("Administrator"))
{
	<div class="modal fade" id="adminDeleteModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content bg-dark border-secondary">
				<div class="modal-header border-secondary">
					<h5 class="modal-title text-white">Admin — Delete Collection</h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
				</div>
				<div class="modal-body text-light">
					You are about to delete <span class="text-info fw-bold">@Model.Title</span>
					by <span class="text-warning fw-bold">@Model.Publisher</span> as an administrator.
					This action cannot be undone.
				</div>
				<div class="modal-footer border-secondary">
					<button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
					<form asp-area="Admin" asp-controller="Collections" asp-action="Delete"
						  asp-route-id="@Model.Id" method="post">
						<button type="submit" class="btn btn-danger rounded-pill px-4">
							<i class="bi bi-shield-fill me-1"></i>Delete
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
}

@section Scripts {
	<script>
		document.addEventListener('DOMContentLoaded', function () {
			var modalElements = document.querySelectorAll('.modal');
			modalElements.forEach(function (modalEl) {
				document.body.appendChild(modalEl);
			});

			document.querySelectorAll('[data-bs-placement]')
				.forEach(el => new bootstrap.Tooltip(el));
		});
	</script>
}



