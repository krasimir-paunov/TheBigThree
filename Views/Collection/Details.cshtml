@using TheBigThree.Web.ViewModels
@model CollectionDetailsViewModel

@{
	ViewBag.Title = Model.Title;
}

<div class="hub-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
	<div class="container py-4">

		@if (TempData["Error"] != null)
		{
			<div class="alert alert-danger shadow-sm mb-4 rounded-pill px-4 text-center">
				<i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
			</div>
		}

		<div class="profile-card mb-4 py-3 px-4 shadow-sm border-secondary border-opacity-25">
			<div class="d-flex flex-wrap justify-content-between align-items-center">

				<div class="d-flex align-items-center gap-4">
					<h2 class="mb-0 fw-bold text-white">@Model.Title</h2>
					<div class="vr bg-secondary opacity-50 d-none d-md-block" style="height: 30px;"></div>
					<div class="small">
						<span class="text-muted d-block" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px;">Curated by</span>
						<span class="text-info fw-bold">@Model.Publisher</span>
					</div>
				</div>

				<div class="d-flex align-items-center gap-4 mt-3 mt-md-0">
					<div class="text-center px-3 border-end border-secondary border-opacity-25">
						<span class="h4 text-warning fw-bold mb-0">⭐ @Model.TotalStars</span>
						<div class="text-muted" style="font-size: 0.6rem; text-transform: uppercase;">Total Stars</div>
					</div>

					<div class="action-buttons">
						@if (User.Identity?.IsAuthenticated == true && User.Identity.Name?.Split('@')[0] != Model.Publisher)
						{
							@if (ViewBag.IsStarred == true)
							{
								<form asp-controller="Collection" asp-action="RemoveStar" asp-route-id="@Model.Id" method="post">
									<button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-4 fw-bold">
										<i class="bi bi-star"></i> Unstar
									</button>
								</form>
							}
							else
							{
								<form asp-controller="Collection" asp-action="Star" asp-route-id="@Model.Id" method="post">
									<button type="submit" class="btn btn-sm btn-warning rounded-pill px-4 fw-bold">
										<i class="bi bi-star-fill"></i> Give Star
									</button>
								</form>
							}
						}
						else if (User.Identity?.IsAuthenticated == true && User.Identity.Name?.Split('@')[0] == Model.Publisher)
						{
							<span class="badge bg-secondary opacity-75 py-2 px-3 rounded-pill" style="font-size: 0.7rem;">
								<i class="bi bi-person-check-fill me-1"></i> My Collection
							</span>
						}
					</div>
				</div>
			</div>
		</div>

		<div class="row g-4 justify-content-center align-items-start">
			@foreach (GameDetailsViewModel game in Model.Games)
			{
				<div class="col-lg-4 col-md-6">
					<div class="card collection-card shadow-lg">
						<div class="p-4 text-center">
							<div class="game-thumb-container rounded p-3 mb-3" style="height: 250px; background: rgba(0,0,0,0.2);">
								<img src="@game.ImageUrl" class="img-fluid h-100 w-100" style="object-fit: contain;" alt="@game.Title">
							</div>

							<h4 class="card-title-gold fw-bold mb-1">@game.Title</h4>
							<span class="badge rounded-pill bg-info text-dark mb-3 px-3" style="font-size: 0.7rem;">@game.Genre</span>

							<p class="text-light opacity-75 px-1" style="font-size: 0.85rem; line-height: 1.5; text-align: justify; white-space: pre-line;">
								@game.Description
							</p>
						</div>
					</div>
				</div>
			}
		</div>

		<div class="row mt-5">
			<div class="col-12 col-lg-8 mx-auto">

				<h4 class="text-white fw-bold mb-4">
					<i class="bi bi-chat-dots-fill me-2 text-info"></i> Comments
				</h4>

				@if (!Model.Comments.Any())
				{
					<p class="text-muted fst-italic">No comments yet. Be the first to share your thoughts!</p>
				}

				@foreach (var comment in Model.Comments)
				{
					<div class="profile-card mb-3 p-3 shadow-sm">
						<div class="d-flex justify-content-between align-items-start">
							<div>
								<span class="text-info fw-bold">@comment.UserName</span>
								<span class="text-muted ms-2" style="font-size: 0.75rem;">
									@comment.CreatedOn.ToString("MMM dd, yyyy")
								</span>
							</div>
							@if (User.Identity?.IsAuthenticated == true && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId)
							{
								<form asp-controller="Comment" asp-action="Delete" method="post">
									<input type="hidden" name="commentId" value="@comment.Id" />
									<input type="hidden" name="collectionId" value="@Model.Id" />
									<button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
										<i class="bi bi-trash"></i>
									</button>
								</form>
							}
						</div>
						<p class="text-light mt-2 mb-0" style="font-size: 0.9rem;">@comment.Content</p>
					</div>
				}

				@if (User.Identity?.IsAuthenticated == true)
				{
					<div class="profile-card mt-4 p-4 shadow-sm">
						<h5 class="text-white fw-bold mb-3">Leave a Comment</h5>
						<form asp-controller="Comment" asp-action="Add" method="post">
							<input type="hidden" name="collectionId" value="@Model.Id" />
							<div class="mb-3">
								<textarea name="Content" id="Content"
									  class="form-control bg-dark text-light border-secondary"
									  rows="3"
									  placeholder="Share your thoughts..."></textarea>
								<span class="text-danger small"></span>
							</div>
							<button type="submit" class="btn btn-info rounded-pill px-4 fw-bold">
								<i class="bi bi-send-fill me-2"></i> Post Comment
							</button>
						</form>
					</div>
				}
			</div>
		</div>

		<div class="text-center mt-5 pb-5">
			<a asp-action="All" class="btn btn-sm btn-outline-light rounded-pill px-4 opacity-50">
				<i class="bi bi-arrow-left me-2"></i> Back to Hub
			</a>
		</div>
	</div>
</div>