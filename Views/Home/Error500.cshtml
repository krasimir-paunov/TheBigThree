@{
    ViewData["Title"] = "Something Went Wrong";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hub-background" style="width: 100vw; margin-left: calc(-50vw + 50%); min-height: 80vh;">
    <div class="container d-flex flex-column justify-content-center align-items-center text-center py-5" style="min-height: 80vh;">
        <h1 class="fw-bold text-danger" style="font-size: 8rem; line-height: 1;">500</h1>
        <h2 class="text-white fw-bold mb-3">Something Went Wrong</h2>
        <p class="text-muted mb-4" style="max-width: 400px;">
            An unexpected error occurred on our end. Please try again later.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-info rounded-pill px-5 fw-bold">
            <i class="bi bi-house-fill me-2"></i> Back to Home
        </a>
    </div>
</div>