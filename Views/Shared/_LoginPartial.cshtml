@using Microsoft.AspNetCore.Identity
@using TheBigThree.Data.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);

        if (User.IsInRole("Administrator"))
        {
            <li class="nav-item d-flex align-items-center me-2">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="btn btn-sm btn-outline-warning rounded-pill">
                    <i class="bi bi-shield-fill me-1"></i>Admin Panel
                </a>
            </li>
        }

        <li class="nav-item">
            <a class="nav-link text-white fw-semibold d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                @if (!string.IsNullOrEmpty(currentUser?.AvatarUrl))
                {
                    <img src="@currentUser.AvatarUrl"
                         class="rounded-circle"
                         style="width: 24px; height: 24px; object-fit: cover; border: 1px solid rgba(13,202,240,0.5);"
                         alt="avatar" />
                }
                else
                {
                    <i class="bi bi-person-circle me-1 text-info"></i>
                }
                Hello, @User.Identity?.Name !
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-white fw-semibold border-0">
                    <i class="bi bi-box-arrow-right me-1 text-danger"></i> Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white fw-semibold px-3" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus-fill me-1"></i> Register
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white fw-semibold px-3" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-door-open-fill me-1"></i> Login
            </a>
        </li>
    }
</ul>