@using Microsoft.AspNetCore.Identity
@using TheBigThree.Data.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav d-flex align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (User.IsInRole("Administrator"))
        {
            <li class="nav-item">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="btn btn-sm btn-outline-warning rounded-pill px-3"
                   style="font-size: 0.78rem; font-weight: 600;">
                    <i class="bi bi-shield-fill me-1"></i>Admin Panel
                </a>
            </li>
        }
        <li class="nav-item">
            <a class="d-flex align-items-center gap-2 text-decoration-none py-2 px-2 rounded navbar-user-link"
               asp-area="Identity" asp-page="/Account/Manage/Index">
                @if (!string.IsNullOrEmpty(currentUser?.AvatarUrl))
                {
                    <img src="@currentUser.AvatarUrl"
                         class="rounded-circle"
                         style="width: 28px; height: 28px; object-fit: cover; border: 1px solid rgba(13,202,240,0.5);"
                         alt="avatar" />
                }
                else
                {
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 28px; height: 28px; background: rgba(13,202,240,0.15); border: 1px solid rgba(13,202,240,0.3); font-size: 0.65rem; font-weight: 700; color: rgba(13,202,240,0.9);">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")
                    </div>
                }
                <span class="text-white fw-semibold" style="font-size: 0.85rem;">
                    Hello, @User.Identity?.Name?.Split('@')[0]
                </span>
            </a>
        </li>
        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-sm rounded-pill px-3 navbar-logout-btn">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a asp-area="Identity" asp-page="/Account/Register"
               class="btn btn-sm btn-outline-info rounded-pill px-3"
               style="font-size: 0.78rem; font-weight: 600;">
                <i class="bi bi-person-plus-fill me-1"></i>Register
            </a>
        </li>
        <li class="nav-item">
            <a asp-area="Identity" asp-page="/Account/Login"
               class="btn btn-sm btn-info rounded-pill px-3 text-dark"
               style="font-size: 0.78rem; font-weight: 700;">
                <i class="bi bi-door-open-fill me-1"></i>Login
            </a>
        </li>
    }
</ul>