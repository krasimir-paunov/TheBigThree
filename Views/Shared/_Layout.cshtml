<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TheBigThree</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TheBigThree.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=2" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom border-secondary box-shadow mb-3 py-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-info" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-controller"></i> THE BIG <span class="text-warning">3</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3 @(currentController == "Home" && currentAction == "Index" ? "active-link" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3 @(currentController == "Collection" && currentAction == "All" ? "active-link" : "")"
                               asp-area="" asp-controller="Collection" asp-action="All">Hub</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3 @(currentController == "Profile" ? "active-link" : "")"
                                   asp-controller="Profile" asp-action="Index">My Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3 @(currentController == "Collection" && currentAction == "Mine" ? "active-link" : "")"
                                   asp-controller="Collection" asp-action="Mine">My Collection</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3 @(currentController == "Home" && currentAction == "Privacy" ? "active-link" : "")"
                               asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center text-white">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="footer bg-dark border-top border-secondary py-2 mt-auto">
        <div class="container d-flex justify-content-between align-items-center">
            <p class="mb-0 text-white-50 small">
                &copy; 2026 <span class="text-info fw-bold">THE BIG 3</span>
            </p>

            <div class="footer-links">
                <a class="text-white-50 text-decoration-none small me-3" asp-controller="Home" asp-action="Privacy">Privacy</a>
                <a class="text-white-50 text-decoration-none small" asp-controller="Collection" asp-action="All">Hub</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <button id="backToTop"
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            title="Back to top"
            class="btn btn-info rounded-circle shadow-lg"
            style="position: fixed; bottom: 30px; right: 30px; width: 45px; height: 45px; opacity: 0; pointer-events: none; z-index: 999; transition: opacity 0.4s ease, transform 0.2s, box-shadow 0.2s;"
            onmouseover="this.style.transform='scale(1.2)'; this.style.boxShadow='0 0 15px rgba(13,202,240,0.7)';"
            onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='';">
        <i class="bi bi-arrow-up"></i>
    </button>

    <script>
        window.addEventListener('scroll', function () {
            var btn = document.getElementById('backToTop');
            if (window.scrollY > 150) {
                btn.style.opacity = '1';
                btn.style.pointerEvents = 'auto';
            } else {
                btn.style.opacity = '0';
                btn.style.pointerEvents = 'none';
            }
        });
    </script>
</body>
</html>