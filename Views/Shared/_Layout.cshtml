<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TheBigThree</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TheBigThree.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=2" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-xxl navbar-dark py-0"
             style="background: linear-gradient(135deg, rgba(5,20,25,0.97) 0%, rgba(8,30,35,0.97) 100%); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(13,202,240,0.15); box-shadow: 0 1px 20px rgba(13,202,240,0.07); min-height: 60px;">
            <div class="container-fluid px-4">

                <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                   asp-area="" asp-controller="Home" asp-action="Index"
                   style="font-family: var(--heading-font); letter-spacing: 1px; font-size: 1.1rem;">
                    <i class="bi bi-controller text-info"></i>
                    <span class="text-white">THE BIG</span>
                    <span class="text-warning">3</span>
                </a>

                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-end">

                    <ul class="navbar-nav gap-1 d-none d-xxl-flex position-absolute start-50 translate-middle-x">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Home" && currentAction == "Index" ? "active-link" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Collection" && currentAction == "All" ? "active-link" : "")"
                               asp-area="" asp-controller="Collection" asp-action="All">Hub</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Profile" ? "active-link" : "")"
                                   asp-area="" asp-controller="Profile" asp-action="Index">My Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Collection" && currentAction == "Mine" ? "active-link" : "")"
                                   asp-area="" asp-controller="Collection" asp-action="Mine">My Collection</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Stats" && currentAction == "Index" ? "active-link" : "")"
                                   asp-area="" asp-controller="Stats" asp-action="Index">Stats</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Leaderboard" && currentAction == "Index" ? "active-link" : "")"
                                   asp-area="" asp-controller="Leaderboard" asp-action="Index">Leaderboard</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3 py-4 @(currentController == "Home" && currentAction == "Privacy" ? "active-link" : "")"
                               asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav d-xxl-none w-100">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Collection" asp-action="All">Hub</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Profile" asp-action="Index">My Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Collection" asp-action="Mine">My Collection</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Stats" asp-action="Index">Stats</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Leaderboard" asp-action="Index">Leaderboard</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div>
        @if (TempData["Error"] != null)
        {
            <div class="container">
                <div class="alert alert-danger mt-3">
                    @TempData["Error"]
                </div>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer style="background: rgba(0,0,0,0.9); border-top: 1px solid rgba(255,255,255,0.06);">
        <div class="container py-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">

                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-controller text-info"></i>
                    <span style="font-family: var(--heading-font); font-size: 0.95rem; letter-spacing: 1px;">
                        <span class="text-white">THE BIG</span> <span class="text-warning">3</span>
                    </span>
                </div>

                <p class="mb-0 text-center" style="font-size: 0.78rem; color: rgba(255,255,255,0.25);">
                    &copy; 2026 The Big Three — Built with passion for gamers.
                </p>

                <div class="d-flex gap-4">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link">
                        Privacy
                    </a>
                    <a asp-area="" asp-controller="Collection" asp-action="All" class="footer-link">
                        Hub
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="footer-link">
                        Home
                    </a>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <button id="backToTop"
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            title="Back to top"
            class="btn btn-info rounded-circle shadow-lg">
        <i class="bi bi-arrow-up"></i>
    </button>

</body>
</html>