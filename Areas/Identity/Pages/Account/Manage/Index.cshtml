@page "/Identity/Account/Manage"
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="manage-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 class="hub-title mb-0">Account Settings</h2>
            <div class="badge bg-info text-dark shadow-sm">Manage your profile</div>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <partial name="_ManageNav" />
            </div>
            <div class="col-md-7">
                <div class="manage-card">
                    <h4 class="text-white fw-bold mb-4">
                        <i class="bi bi-person-fill text-info me-2"></i>Profile
                    </h4>
                    <partial name="_StatusMessage" for="StatusMessage" />
                    <form id="profile-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                        <div class="mb-3">
                            <label class="manage-label">Username</label>
                            <input asp-for="Username" class="form-control glass-input" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="manage-label">Email</label>
                            <input asp-for="Email" class="form-control glass-input" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="manage-label">Avatar URL</label>
                            <input asp-for="AvatarUrl" class="form-control glass-input" placeholder="https://..." />
                            <small class="text-muted">Paste a direct image URL for your avatar</small>
                        </div>
                        <div class="mb-4">
                            <label class="manage-label">Member Since</label>
                            <p class="text-white-50 mb-0">@Model.MemberSince.ToString("MMMM dd, yyyy")</p>
                        </div>
                        <button id="update-profile-button" type="submit" class="btn btn-info rounded-pill px-5 fw-bold w-100">
                            <i class="bi bi-check-lg me-2"></i>Save Changes
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}