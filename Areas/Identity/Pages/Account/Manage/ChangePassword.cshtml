@page "/Identity/Account/Manage/ChangePassword"
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="manage-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 class="hub-title mb-0">Account Settings</h2>
            <div class="badge bg-info text-dark shadow-sm">Manage your profile</div>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <partial name="_ManageNav" />
            </div>
            <div class="col-md-7">
                <div class="manage-card">
                    <h4 class="text-white fw-bold mb-4">
                        <i class="bi bi-lock-fill text-info me-2"></i>Change Password
                    </h4>
                    <partial name="_StatusMessage" for="StatusMessage" />
                    <form id="change-password-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                        <div class="mb-3">
                            <label class="manage-label">Current Password</label>
                            <input asp-for="Input.OldPassword" class="form-control glass-input" autocomplete="current-password" />
                            <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="manage-label">New Password</label>
                            <input asp-for="Input.NewPassword" class="form-control glass-input" autocomplete="new-password" />
                            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="manage-label">Confirm New Password</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control glass-input" autocomplete="new-password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <button id="change-password-button" type="submit" class="btn btn-info rounded-pill px-5 fw-bold w-100">
                            <i class="bi bi-lock-fill me-2"></i>Update Password
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}