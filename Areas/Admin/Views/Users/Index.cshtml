@using TheBigThree.Web.ViewModels
@model IEnumerable<UserManagementViewModel>

@{
    ViewBag.Title = "User Management";
}

@section Styles {
    <style>
        .admin-background {
            background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)), url('/images/backgrounds/mine-background.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
        }

        .admin-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 1rem;
        }

        .admin-table {
            color: rgba(255, 255, 255, 0.9);
        }

            .admin-table thead tr {
                border-bottom: 1px solid rgba(255, 255, 255, 0.15);
            }

            .admin-table thead th {
                font-size: 0.75rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.6);
                font-weight: 500;
                padding: 0.75rem 1rem;
                border: none;
            }

            .admin-table tbody tr {
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                transition: background 0.15s ease;
            }

                .admin-table tbody tr:hover {
                    background: rgba(255, 255, 255, 0.04);
                }

            .admin-table tbody td {
                padding: 0.85rem 1rem;
                vertical-align: middle;
                border: none;
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.85);
            }

        .user-avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(13, 202, 240, 0.15);
            border: 1px solid rgba(13, 202, 240, 0.3);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 600;
            color: rgba(13, 202, 240, 0.9);
            margin-right: 10px;
        }

        .stat-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 3px 10px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 500;
        }
    </style>
}

<div class="admin-background overflow-hidden" style="width: 100vw; margin-left: calc(-50vw + 50%);">
    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 class="hub-title mb-0">User Management</h2>
            <div class="badge bg-warning text-dark shadow-sm">Administrator Panel</div>
        </div>

        <div class="mb-3">
            <input type="text"
                   id="userSearch"
                   class="form-control bg-dark text-light border-secondary"
                   placeholder="Search by username..."
                   style="max-width: 320px; border-radius: 50px; padding-left: 1rem;" />
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3 px-1">
            <span style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">
                @Model.Count() users registered
            </span>
            <a asp-area="Admin" asp-controller="Collections" asp-action="Index"
               class="btn btn-sm btn-outline-info rounded-pill">
                <i class="bi bi-collection-fill me-1"></i>Manage Collections
            </a>
        </div>

        <div class="admin-card p-0 overflow-hidden">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Collection</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (UserManagementViewModel user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span class="user-avatar-circle">
                                        @user.Username.Substring(0, 1).ToUpper()
                                    </span>
                                    <span class="fw-semibold text-white">@user.Username</span>
                                </div>
                            </td>
                            <td style="color: rgba(255,255,255,0.75);">@user.Email</td>
                            <td>
                                @if (user.Role == "Administrator")
                                {
                                    <span class="stat-pill" style="background: rgba(220,53,69,0.15); color: #ff6b7a; border: 1px solid rgba(220,53,69,0.3);">
                                        <i class="bi bi-shield-fill" style="font-size: 0.7rem;"></i> Administrator
                                    </span>
                                }
                                else
                                {
                                    <span class="stat-pill" style="background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.75); border: 1px solid rgba(255,255,255,0.25);">
                                        <i class="bi bi-person-fill" style="font-size: 0.7rem;"></i> User
                                    </span>
                                }
                            </td>
                            <td>
                                @if (user.HasCollection)
                                {
                                    <span class="stat-pill" style="background: rgba(25,135,84,0.15); color: #6fcf97; border: 1px solid rgba(25,135,84,0.3);">
                                        <i class="bi bi-check-circle-fill" style="font-size: 0.7rem;"></i> Yes
                                    </span>
                                }
                                else
                                {
                                    <span class="stat-pill" style="background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.08);">
                                        <i class="bi bi-dash-circle" style="font-size: 0.7rem;"></i> No
                                    </span>
                                }
                            </td>
                            <td>
                                @if (user.Role != "Administrator")
                                {
                                    <button type="button"
                                            class="btn btn-sm rounded-pill"
                                            style="background: rgba(220,53,69,0.15); color: #ff6b7a; border: 1px solid rgba(220,53,69,0.3); font-size: 0.8rem;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteUserModal-@user.Id">
                                        <i class="bi bi-trash3-fill me-1"></i>Delete
                                    </button>

                                    <div class="modal fade" id="deleteUserModal-@user.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content bg-dark border-secondary">
                                                <div class="modal-header border-secondary">
                                                    <h5 class="modal-title text-white">Delete User</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body text-light">
                                                    Are you sure you want to delete <span class="text-info fw-bold">@user.Username</span>?
                                                    This will permanently remove their account and cannot be undone.
                                                </div>
                                                <div class="modal-footer border-secondary">
                                                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                                    <form asp-area="Admin" asp-controller="Users" asp-action="Delete"
                                                          asp-route-id="@user.Id" method="post">
                                                        <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span style="font-size: 0.78rem; color: rgba(255,255,255,0.2);">
                                        <i class="bi bi-lock-fill me-1"></i>Protected
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modalElements = document.querySelectorAll('.modal');
            modalElements.forEach(function (modalEl) {
                document.body.appendChild(modalEl);
            });

            const searchInput = document.getElementById('userSearch');
            searchInput.addEventListener('input', function () {
                const query = this.value.toLowerCase();
                const rows = document.querySelectorAll('.admin-table tbody tr');
                rows.forEach(function (row) {
                    const username = row.querySelector('td:first-child').textContent.toLowerCase();
                    row.style.display = username.includes(query) ? '' : 'none';
                });
            });
        });
    </script>
}